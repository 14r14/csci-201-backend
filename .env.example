# Copy this file to `.env` in the project root and adjust values.
# `.env` is gitignored; never commit real passwords.
#
# The app uses MySQL by default (tables live on your server — visible in any SQL client).
# `mvn test` uses in-memory H2 only (see src/test/resources/application.yml).

# --- MySQL (defaults match application.yml placeholders) ---
DB_USER=changeme
DB_PASSWORD=changeme
# Alternative if you prefer: MYSQL_PASSWORD=changeme

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=csci201

# Optional: use in-memory H2 for `mvn spring-boot:run` when you have no MySQL (not for inspecting data in a client).
# SPRING_PROFILES_ACTIVE=h2

# --- Optional: server ---
# SERVER_PORT=8080
